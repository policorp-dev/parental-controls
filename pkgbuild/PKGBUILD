# Maintainer: Bruno Goncalves <bigbruno@gmail.com>

pkgname=big-parental-controls
pkgver=$(date +%y.%m.%d)
pkgrel=$(date +%H%M)
arch=('x86_64')
license=('GPL')
url="https://github.com/biglinux/$pkgname"
pkgdesc="Parental controls and supervised accounts for BigLinux — ECA Digital compliance"
depends=(
    'python'
    'python-gobject'
    'gtk4'
    'libadwaita'
    'libmalcontent'
    'accountsservice'
    'polkit'
    'gettext'
    'acl'
)
makedepends=(
    'rust'
    'cargo'
)
optdepends=(
    'nftables: DNS redirect enforcement per supervised user (recommended)'
)
source=("git+https://github.com/biglinux/$pkgname.git")
md5sums=(SKIP)
install=$pkgname.install

build() {
    # Verify default folder
    if [ -d "$srcdir/$pkgname/$pkgname" ]; then
        InternalDir="$srcdir/$pkgname/$pkgname"
    else
        InternalDir="$srcdir/$pkgname"
    fi

    # Build Rust unified daemon (age signal + parental monitor)
    cd "$InternalDir/../big-age-signal"
    cargo build --release
}

package() {
    # Verify default folder
    if [ -d "$srcdir/$pkgname/$pkgname" ]; then
        InternalDir="$srcdir/$pkgname/$pkgname"
    else
        InternalDir="$srcdir/$pkgname"
    fi

    # Copy files
    if [ -d "$InternalDir/usr" ]; then
        cp -r "$InternalDir/usr" "$pkgdir/"
    fi

    # Install unified Rust daemon binary
    install -Dm755 "$InternalDir/../big-age-signal/target/release/big-parental-daemon" \
        "$pkgdir/usr/lib/big-parental-controls/big-parental-daemon"

    # Symlink for backward compatibility (big-age-signal → big-parental-daemon)
    ln -sf /usr/lib/big-parental-controls/big-parental-daemon \
        "$pkgdir/usr/bin/big-age-signal"

    # Install Python package
    local site_packages="$pkgdir/$(python -c 'import site; print(site.getsitepackages()[0])')"
    install -dm755 "$site_packages/big_parental_controls"
    cp -r "$InternalDir/../src/big_parental_controls/"* "$site_packages/big_parental_controls/"

    # Set executable permissions
    chmod +x "$pkgdir/usr/bin/big-parental-controls" 2>/dev/null || true
    chmod +x "$pkgdir/usr/lib/big-parental-controls/group-helper" 2>/dev/null || true
    chmod +x "$pkgdir/usr/lib/big-parental-controls/acl-reapply" 2>/dev/null || true
    chmod +x "$pkgdir/usr/lib/big-parental-controls/time-check" 2>/dev/null || true
    chmod +x "$pkgdir/usr/lib/big-parental-controls/pam-time-message" 2>/dev/null || true

    # Create state directory (755 so the app user can read user-profiles.json)
    install -dm755 "$pkgdir/var/lib/big-parental-controls"
    install -dm700 "$pkgdir/var/lib/big-parental-controls/activity"

    # Install compiled locale files
    if [ -d "$InternalDir/../usr/share/locale" ]; then
        cp -r "$InternalDir/../usr/share/locale" "$pkgdir/usr/share/"
    fi
}
