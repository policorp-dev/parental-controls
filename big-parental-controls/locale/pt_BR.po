#: src/big_parental_controls/ui/pages/main_view.py:188
msgid "ECA Digital — Brazil"
msgstr "ECA Digital — Brasil"

#: src/big_parental_controls/ui/pages/main_view.py:190
msgid ""
"Law 15.211/2025 — Safety, Privacy, and Parental Control for Children in the "
"Digital Environment. This app implements Art. 12 (age verification), Art. 13 "
"(data minimization), Art. 17 (protective measures), and Art. 18 (activity "
"monitoring)."
msgstr ""
"Lei 15.211/2025 — Segurança, Privacidade e Controle Parental para Crianças "
"no Ambiente Digital. Este app implementa Art. 12 (verificação de idade), "
"Art. 13 (minimização de dados), Art. 17 (medidas protetivas) e Art. 18 "
"(monitoramento de atividade)."

#: src/big_parental_controls/ui/pages/main_view.py:198
msgid "LGPD — Brazil"
msgstr "LGPD — Brasil"

#: src/big_parental_controls/ui/pages/main_view.py:200
msgid ""
"Law 13.709/2018 — General Data Protection Law. Compliant with Art. 14 "
"(children's data requires specific parental consent), Art. 18 (right to "
"access and delete data), Art. 46 (security)."
msgstr ""
"Lei 13.709/2018 — Lei Geral de Proteção de Dados. Conforme Art. 14 (dados de "
"crianças requerem consentimento parental específico), Art. 18 (direito de "
"acesso e exclusão de dados), Art. 46 (segurança)."

#: src/big_parental_controls/ui/pages/main_view.py:207
msgid "GDPR — European Union"
msgstr "GDPR — União Europeia"

#: src/big_parental_controls/ui/pages/main_view.py:209
msgid ""
"Regulation 2016/679 — General Data Protection Regulation. Compliant with "
"Art. 8 (child consent via parent), Art. 13 (transparent information), Art. "
"17 (right to erasure), Art. 20 (data portability), Art. 25 (privacy by "
"design)."
msgstr ""
"Regulamento 2016/679 — Regulamento Geral de Proteção de Dados. Conforme Art. "
"8 (consentimento de criança via responsável), Art. 13 (informação "
"transparente), Art. 17 (direito ao apagamento), Art. 20 (portabilidade de "
"dados), Art. 25 (privacidade por design)."

#: src/big_parental_controls/ui/pages/main_view.py:217
msgid "UK Children's Code"
msgstr "Código de Proteção Infantil do Reino Unido"

#: src/big_parental_controls/ui/pages/main_view.py:219
msgid ""
"Age Appropriate Design Code — 15 standards for child-safe digital services, "
"including data minimization, default protections, and parental controls."
msgstr ""
"Código de Design Adequado à Idade — 15 padrões para serviços digitais "
"seguros para crianças, incluindo minimização de dados, proteções padrão e "
"controles parentais."

#: src/big_parental_controls/ui/pages/main_view.py:226
msgid "EU Digital Services Act"
msgstr "Lei de Serviços Digitais da UE"

#: src/big_parental_controls/ui/pages/main_view.py:228
msgid ""
"Regulation 2022/2065 — Transparency, user safety, and minors' protection in "
"digital platforms."
msgstr ""
"Regulamento 2022/2065 — Transparência, segurança do usuário e proteção de "
"menores em plataformas digitais."

