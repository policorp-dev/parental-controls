#!/usr/bin/env python3
"""Check supervised users time limits (daily minutes + schedule).

Executed by big-parental-time-check.timer every minute.
Terminates active graphical sessions that have exceeded their limits.
"""

import grp
import json
import os
import re
import signal
import subprocess
import sys
import time
from datetime import date, datetime
from pathlib import Path

STATE_DIR   = Path("/var/lib/big-parental-controls")
LIMITS_FILE = STATE_DIR / "time-limits.json"
USAGE_FILE  = STATE_DIR / "time-state.json"
TIME_CONF   = Path("/etc/security/time.conf")
TODAY       = date.today().isoformat()
_NOW        = datetime.now()
_NOW_WDAY   = _NOW.weekday()   # 0=Mon … 6=Sun
_NOW_MIN    = _NOW.hour * 60 + _NOW.minute


def _supervised_users() -> list[str]:
    try:
        return [m for m in grp.getgrnam("supervised").gr_mem if m]
    except KeyError:
        return []


def get_active_graphical_session(username: str) -> str | None:
    """Return the session ID of the user's active graphical session, or None."""
    try:
        state = subprocess.run(
            ["loginctl", "show-user", username, "--property=State", "--value"],
            capture_output=True, text=True, check=True,
        ).stdout.strip()
        if state != "active":
            return None
        sessions_out = subprocess.run(
            ["loginctl", "show-user", username, "--property=Sessions", "--value"],
            capture_output=True, text=True, check=True,
        ).stdout.strip()
        for sid in sessions_out.split():
            typ = subprocess.run(
                ["loginctl", "show-session", sid, "--property=Type", "--value"],
                capture_output=True, text=True, check=False,
            ).stdout.strip()
            if typ in ("x11", "wayland", "mir"):
                return sid
    except subprocess.CalledProcessError:
        pass
    return None


def terminate_session(username: str, session_id: str, reason: str) -> None:
    """SIGTERM the graphical session leader; restart sddm if session persists."""
    print(f"Terminating {username} session {session_id}: {reason}")
    try:
        leader = subprocess.run(
            ["loginctl", "show-session", session_id, "--property=Leader", "--value"],
            capture_output=True, text=True, check=False,
        ).stdout.strip()
        if leader.isdigit():
            os.kill(int(leader), signal.SIGTERM)
            print(f"  SIGTERM → pid {leader}")
        else:
            subprocess.run(["loginctl", "terminate-session", session_id], check=False)
        time.sleep(5)
    except Exception as exc:
        print(f"  terminate error: {exc}", file=sys.stderr)

    try:
        lingering = subprocess.run(
            ["loginctl", "show-user", username, "--property=State", "--value"],
            capture_output=True, text=True, check=False,
        ).stdout.strip()
        if lingering in ("active", "online"):
            subprocess.run(["systemctl", "restart", "sddm"], check=False)
            print("  sddm restarted")
    except Exception:
        pass


def notify_user(username: str, summary: str, body: str) -> None:
    try:
        subprocess.run(
            ["sudo", "-u", username, "notify-send", "--urgency=critical", summary, body],
            check=False, timeout=5,
        )
    except Exception:
        pass


# ── Schedule helpers ──────────────────────────────────────────────────────────

_DAY_MAP = {"Mo": 0, "Tu": 1, "We": 2, "Th": 3, "Fr": 4, "Sa": 5, "Su": 6}


def _day_applies(day_str: str) -> bool:
    if not day_str:
        return True
    if "Al" in day_str:
        base = set(range(7))
    elif "Wk" in day_str:
        base = set(range(5))
    elif "Wd" in day_str:
        base = {5, 6}
    else:
        base = set()
    remain = day_str.replace("Al", "").replace("Wk", "").replace("Wd", "")
    i = 0
    while i + 1 < len(remain):
        code = remain[i : i + 2]
        if code in _DAY_MAP:
            base.add(_DAY_MAP[code])
            i += 2
        else:
            i += 1
    return _NOW_WDAY in base


def is_within_schedule(username: str) -> bool:
    """True if current time is within the user's allowed schedule, or no rule exists."""
    if not TIME_CONF.exists():
        return True
    try:
        content = TIME_CONF.read_text()
    except OSError:
        return True

    rule = None
    for line in content.splitlines():
        line = line.strip()
        if not line or line.startswith("#"):
            continue
        parts = line.split(";", 3)
        if len(parts) == 4 and parts[2] == username:
            rule = parts[3].strip()

    if rule is None:
        return True

    for seg in rule.split("|"):
        m = re.search(r"(\d{2})(\d{2})-(\d{2})(\d{2})$", seg)
        if not m:
            continue
        start_min = int(m.group(1)) * 60 + int(m.group(2))
        end_min   = int(m.group(3)) * 60 + int(m.group(4))
        if _day_applies(seg[: m.start()]) and start_min <= _NOW_MIN < end_min:
            return True

    return False


# ── Load state ────────────────────────────────────────────────────────────────

STATE_DIR.mkdir(parents=True, exist_ok=True)

if not _supervised_users():
    sys.exit(0)

try:
    limits: dict = json.loads(LIMITS_FILE.read_text())
except (OSError, json.JSONDecodeError):
    limits = {}

try:
    usage: dict = json.loads(USAGE_FILE.read_text())
except (OSError, json.JSONDecodeError):
    usage = {}

if usage.get("_date") != TODAY:
    usage = {"_date": TODAY}

changed = False

# ── Daily minute limit ────────────────────────────────────────────────────────

for username, cfg in limits.items():
    daily_minutes = cfg.get("daily_minutes", 0)
    if daily_minutes <= 0:
        continue

    session_id = get_active_graphical_session(username)
    if session_id is None:
        continue

    prev_used  = usage.get(username, 0)
    total_used = prev_used + 1
    usage[username] = total_used
    changed = True

    remaining = daily_minutes - total_used

    if total_used >= daily_minutes:
        notify_user(
            username,
            "Tempo diário esgotado",
            f"Seu tempo de uso diário de {daily_minutes} min foi atingido.",
        )
        if total_used >= daily_minutes + 1:
            terminate_session(username, session_id,
                              f"daily limit {total_used}/{daily_minutes} min")
    elif remaining in (5, 1):
        notify_user(
            username,
            f"Aviso — {remaining} min restante(s)",
            f"Seu tempo diário acaba em {remaining} minuto(s).",
        )

# ── Schedule enforcement ──────────────────────────────────────────────────────

for username in _supervised_users():
    if is_within_schedule(username):
        continue

    session_id = get_active_graphical_session(username)
    if session_id is None:
        continue

    notify_user(username, "Horário de uso encerrado",
                "O período de uso permitido terminou.")
    terminate_session(username, session_id, "outside allowed schedule")

# ── Persist usage ─────────────────────────────────────────────────────────────

if changed:
    usage["_date"] = TODAY
    USAGE_FILE.write_text(json.dumps(usage, indent=2))
