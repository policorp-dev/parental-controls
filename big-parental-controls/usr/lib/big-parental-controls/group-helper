        [[ -z "$2" ]] && { echo "Usage: activity-sessions USERNAME DAYS" >&2; exit 1; }
        validate_username "$2"
        days="${3:-7}"
        # Validate that days is numeric (1-365)
        if ! [[ "$days" =~ ^[0-9]+$ ]] || [[ "$days" -lt 1 ]] || [[ "$days" -gt 365 ]]; then
            echo "Invalid days parameter (1-365)" >&2
            exit 1
